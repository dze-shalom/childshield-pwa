# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Groq API (for AI matching of found children vs missing alerts) ───────────
# Get your key at: console.groq.com (free)
GROQ_API_KEY=your-groq-api-key-here

# ── Web Push (background notifications — like WhatsApp) ───────────────────────
# Generate your VAPID key pair once with:
#   npx web-push generate-vapid-keys
# Paste the public key here (browser uses it to subscribe).
# Set the private key + subject as Supabase secrets (never expose in frontend):
#   supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... VAPID_SUBJECT=mailto:you@example.com
VITE_VAPID_PUBLIC_KEY=

# ── Optional: moderator webhook ───────────────────────────────────────────────
# POST is sent here when a new incident or abuse report is submitted.
# Use Make.com or Zapier to forward to email / WhatsApp.
VITE_MODERATOR_WEBHOOK=
