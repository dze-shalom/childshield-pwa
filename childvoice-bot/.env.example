# ChildVoice Bot — Environment Variables
# Copy this to .env and fill in your values

# Groq API (FREE — get your key at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Twilio (for WhatsApp messaging)
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Supabase (same project as the PWA)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Server
PORT=3001

# Your deployed bot URL — required for Twilio signature validation in production.
# Leave unset for local dev (validation is skipped when this is missing).
# Example: https://childvoice-bot.onrender.com
WEBHOOK_URL=

# Your PWA app URL — used in the shareable alert message sent after a report.
# Example: https://childshield.vercel.app
WEBAPP_URL=
